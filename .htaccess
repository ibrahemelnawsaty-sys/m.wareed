# ============================================================
#  وريد — تحويل احتياطي لجذر المستند إلى مجلد Laravel /public
# ------------------------------------------------------------
#  يُستخدم فقط على الاستضافة المشتركة التي يتعذّر فيها توجيه
#  Document Root مباشرة إلى /public.
#  الأفضل أمنياً: وجّه جذر المستند إلى /public في hPanel — حينها
#  يبقى هذا الملف خارج المجلد المكشوف ولا يُقرأ (وهو الأسلم).
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # امنع الوصول المباشر للملفات/المجلدات الحسّاسة في الجذر (دفاع متعدّد الطبقات)
    RewriteRule ^(\.env|\.env\..*|composer\.(json|lock)|package(-lock)?\.json|artisan|phpunit\.xml|pint\.json|phpstan\.neon|deploy\.sh|vite\.config\.js)$ - [F,L]
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor|docs|node_modules|\.git|\.github|\.claude)(/.*)?$ - [F,L]

    # حوّل كل ما تبقّى إلى مجلد public (الواجهة الأمامية لـ Laravel)
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# امنع الملفات المخفية (.env و .git وغيرها) حتى لو تعطّل mod_rewrite
<FilesMatch "^\.(?!well-known)">
    Require all denied
</FilesMatch>

Options -Indexes
