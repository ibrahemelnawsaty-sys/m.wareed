# ============================================================
#  وريد — قالب بيئة الإنتاج (m.wareed.vip)
#  انسخه إلى .env على الخادم واملأ الأسرار هناك فقط.
#  لا ترفع .env إطلاقاً (مُتجاهَل في git). الدستور §13.
# ============================================================

APP_NAME="وريد"
APP_ENV=production
APP_KEY=                      # توليده على الخادم: php artisan key:generate
APP_DEBUG=false
APP_URL=https://m.wareed.vip

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_EG

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ----- قاعدة بيانات Hostinger MySQL -----
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u828479444_M
DB_USERNAME=u828479444_M
DB_PASSWORD=                  # السرّ الحقيقي على الخادم فقط

# ----- الجلسة (HTTPS) -----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=null

# ----- الطابور/الكاش (بلا Redis — ADR-03/§14) -----
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# ----- البريد (log مؤقتاً؛ اضبط SMTP لتفعيل تأكيد البريد) -----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@m.wareed.vip"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
#  WhatsApp Cloud API (Meta) — الأسرار على الخادم فقط
# ============================================================
WHATSAPP_APP_SECRET=          # Meta ← Settings ← Basic ← App Secret
WHATSAPP_VERIFY_TOKEN=        # نفس القيمة التي تضعها في Meta (راجع DEPLOY.md)
WHATSAPP_API_VERSION=v21.0
WHATSAPP_GRAPH_BASE=https://graph.facebook.com

# ============================================================
#  Gemini — المفتاح على الخادم فقط
# ============================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT=20
GEMINI_DAILY_MESSAGE_CAP=0
GEMINI_PLAYGROUND_DAILY_CAP=200

VITE_APP_NAME="${APP_NAME}"
